{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Identity Server",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/Backend/IdentityProvider/src/IdentityServer/bin/Debug/net9.0/IdentityServer.dll",
      "cwd": "${workspaceFolder}/Backend/IdentityProvider/src/IdentityServer",
      "console": "integratedTerminal",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:44320"
      }
    },
    {
      "name": "Identity gRPC",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/Backend/IdentityProvider/src/IdentityServer.GrpcServer/bin/Debug/net9.0/IdentityServer.GrpcServer.dll",
      "cwd": "${workspaceFolder}/Backend/IdentityProvider/src/IdentityServer.GrpcServer",
      "console": "integratedTerminal",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:6829"
      }
    },
    {
      "name": "FileManager gRPC",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/Backend/FileManager/src/FileManager.GrpcServer/bin/Debug/net9.0/FileManager.GrpcServer.dll",
      "cwd": "${workspaceFolder}/Backend/FileManager/src/FileManager.GrpcServer",
      "console": "integratedTerminal",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5060"
      }
    },
    {
      "name": "FileManager Web",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/Backend/FileManager/src/FileManager.WebUI/bin/Debug/net9.0/FileManager.WebUI.dll",
      "cwd": "${workspaceFolder}/Backend/FileManager/src/FileManager.WebUI",
      "console": "integratedTerminal",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:6823"
      }
    },
    {
      "name": "Captcha Provider",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/Backend/CaptchaProvider/CaptchaProvider.WebUI/bin/Debug/net9.0/CaptchaProvider.WebUI.dll",
      "cwd": "${workspaceFolder}/Backend/CaptchaProvider/CaptchaProvider.WebUI",
      "console": "integratedTerminal",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5254"
      }
    },
    {
      "name": "UserManager API",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/Backend/IdentityProvider/src/IdentityServer.UserManagerAPI/bin/Debug/net9.0/IdentityServer.UserManagerAPI.dll",
      "cwd": "${workspaceFolder}/Backend/IdentityProvider/src/IdentityServer.UserManagerAPI",
      "console": "integratedTerminal",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5074"
      }
    },
    {
      "name": "WorkFlow API",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/Backend/WorkFlow/src/WorkFlow.WebUI/bin/Debug/net9.0/WorkFlow.WebUI.dll",
      "cwd": "${workspaceFolder}/Backend/WorkFlow/src/WorkFlow.WebUI",
      "console": "integratedTerminal",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:6022"
      }
    },
    {
      "name": "Healan WebApi",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/Backend/Healan/src/Healan.WebApi/bin/Debug/net9.0/Healan.WebApi.dll",
      "cwd": "${workspaceFolder}/Backend/Healan/src/Healan.WebApi",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:6128"
      }
    },
    {
      "name": "Healan Frontend",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm.cmd run start:healan",
      "cwd": "${workspaceFolder}/Frontend/tse_client_workspace"
    },
    {
      "name": "Healan Portal (Public Site)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm.cmd run start:portal",
      "cwd": "${workspaceFolder}/Frontend/tse_client_workspace"
    }
  ],
  "compounds": [
    {
      "name": "Healan: Full Stack",
      "preLaunchTask": "prepare-healan-full-stack",
      "configurations": [
        "Captcha Provider",
        "Identity Server",
        "Identity gRPC",
        "FileManager gRPC",
        "FileManager Web",
        "UserManager API",
        "WorkFlow API",
        "Healan WebApi",
        "Healan Portal (Public Site)",
        "Healan Frontend"
      ],
      "stopAll": true,
      "presentation": {
        "group": "Healan",
        "order": 1
      }
    },
    {
      "name": "Healan: Clinic",
      "preLaunchTask": "prepare-healan-full-stack",
      "configurations": [
        "Captcha Provider",
        "Identity Server",
        "Identity gRPC",
        "FileManager gRPC",
        "FileManager Web",
        "UserManager API",
        "WorkFlow API",
        "Healan WebApi",
        "Healan Frontend"
      ],
      "stopAll": true,
      "presentation": {
        "group": "Healan",
        "order": 2
      }
    },
    {
      "name": "Healan: Backend Only",
      "preLaunchTask": "prepare-healan-full-stack",
      "configurations": [
        "Captcha Provider",
        "Identity Server",
        "Identity gRPC",
        "FileManager gRPC",
        "FileManager Web",
        "Healan WebApi"
      ],
      "stopAll": true,
      "presentation": {
        "group": "Healan",
        "order": 3
      }
    },
    {
      "name": "Healan: Frontend Only",
      "preLaunchTask": "kill-healan-dev-ports",
      "configurations": [
        "Healan Portal (Public Site)",
        "Healan Frontend"
      ],
      "stopAll": true,
      "presentation": {
        "group": "Healan",
        "order": 4
      }
    }
  ]
}
