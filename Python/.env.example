# OpenAI-compatible API (OpenAI, Azure OpenAI, Ollama, LM Studio, ...)
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# برای فارسی: gpt-4o یا gpt-4o-mini | لوکال: qwen2.5:7b
OPENAI_MODEL=gpt-4o-mini

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# RAG — embedding فارسی (اولین اجرا مدل را از HuggingFace دانلود می‌کند)
# simple | chromadb | heydariAI/persian-embeddings
EMBEDDING_MODEL=simple
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION=healan_rag

# منبع داده: excel | sqlserver
DATA_SOURCE=excel
EXCEL_FILE_PATH=data/sample.xlsx
RAG_AUTO_INGEST=true
RAG_TOP_K=5

# SQL Server (فاز بعد — DATA_SOURCE=sqlserver)
# SQL_SERVER_CONNECTION_STRING=mssql+pyodbc://user:pass@server/db?driver=ODBC+Driver+17+for+SQL+Server
# SQL_SERVER_QUERY=SELECT Id, FullName, Specialty, Phone FROM Doctors
