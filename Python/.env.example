# OpenAI-compatible API — برای Ollama لوکال:
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_MODEL=qwen2.5:3b

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# RAG — embedding فارسی
# heydariAI/persian-embeddings (پیشنهادی برای فارسی) | simple (آفلاین تست)
EMBEDDING_MODEL=heydariAI/persian-embeddings
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION=healan_rag

# منبع داده Healan
DATA_SOURCE=sqlserver
SQL_SERVER_USE_HEALAN_BUNDLE=true
SQL_SERVER_CONNECTION_STRING=mssql+pyodbc://sa:123@LAPTOP-VECKM0LE\\MSSQL/Healan?driver=ODBC+Driver+17+for+SQL+Server

RAG_AUTO_INGEST=true
RAG_TOP_K=5
RAG_ANSWER_MODE=direct
RAG_SIMILARITY_THRESHOLD=0.55
RAG_SYNC_ENABLED=true
RAG_SYNC_INTERVAL_MINUTES=10

# خلاصه بلاگ و نظرات (مدل از UI / RagSettings هم قابل تغییر است)
RAG_SUMMARIZE_ENABLED=true
RAG_SUMMARIZE_MODEL=qwen2.5:3b
RAG_SUMMARIZE_MAX_TOKENS=400
RAG_SUMMARIZE_MAX_INPUT_CHARS=8000
RAG_SUMMARIZE_SKIP_IF_SHORTER_THAN=280
RAG_SUMMARIZE_FALLBACK_CHARS=600

# Speech-to-text (faster-whisper، فارسی)
STT_ENABLED=true
STT_MODEL=small
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=fa

# Excel (فقط برای تست)
# DATA_SOURCE=excel
# EXCEL_FILE_PATH=data/sample.xlsx