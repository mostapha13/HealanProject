# OpenAI-compatible API (optional — RAG direct mode works without LLM)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# RAG — embedding فارسی
# heydariAI/persian-embeddings (پیشنهادی برای فارسی) | simple (آفلاین تست)
EMBEDDING_MODEL=heydariAI/persian-embeddings
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION=healan_rag

# منبع داده Healan
DATA_SOURCE=sqlserver
SQL_SERVER_USE_HEALAN_BUNDLE=true
SQL_SERVER_CONNECTION_STRING=mssql+pyodbc://sa:123@LAPTOP-VECKM0LE\\MSSQL/Healan?driver=ODBC+Driver+17+for+SQL+Server

RAG_AUTO_INGEST=true
RAG_TOP_K=5
RAG_ANSWER_MODE=direct
RAG_SIMILARITY_THRESHOLD=0.55
RAG_SYNC_ENABLED=true
RAG_SYNC_INTERVAL_MINUTES=10

# Excel (فقط برای تست)
# DATA_SOURCE=excel
# EXCEL_FILE_PATH=data/sample.xlsx
