# کپی کنید به docker/config/python/.env
# (وقتی سرویس Python RAG به compose اضافه شد)

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

HOST=0.0.0.0
PORT=8000
DEBUG=false

EMBEDDING_MODEL=heydariAI/persian-embeddings
CHROMA_PERSIST_DIR=/data/chroma
CHROMA_COLLECTION=healan_rag

DATA_SOURCE=sqlserver
SQL_SERVER_USE_HEALAN_BUNDLE=true
SQL_SERVER_CONNECTION_STRING=mssql+pyodbc://sa:YourStrong!Passw0rd@sqlserver:1433/Healan?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

RAG_AUTO_INGEST=true
RAG_TOP_K=5
RAG_ANSWER_MODE=direct
RAG_SIMILARITY_THRESHOLD=0.55
RAG_SYNC_ENABLED=true
RAG_SYNC_INTERVAL_MINUTES=10
