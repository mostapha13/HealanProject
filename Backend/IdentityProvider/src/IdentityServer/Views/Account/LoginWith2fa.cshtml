@using System.Collections.Generic
@using System.Linq
@using Microsoft.AspNetCore.Http

@model LoginWith2faViewModel

@{
    ViewData["Title"] = "تأیید دو مرحله‌ای";
}

<div class="healan-login-card">
    <header class="healan-login-card__header">
        <div class="healan-login-card__badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            تأیید هویت
        </div>
        <h1 class="healan-login-card__title">ورود دو مرحله‌ای</h1>
        <p class="healan-login-card__subtitle">کد ارسال‌شده به تلفن همراه خود را وارد کنید.</p>
    </header>

    <form class="healan-login-form" asp-route-returnurl="@ViewData["ReturnUrl"]" asp-controller="Account" asp-action="LoginWith2fa" asp-antiforgery="true" method="post">
        @Html.HiddenFor(x => x.ReturnUrl)

        <div class="healan-field">
            <label asp-for="TwoFactorCode">کد تأیید</label>
            <input asp-for="TwoFactorCode" type="text" placeholder="کد ۶ رقمی" autocomplete="one-time-code" inputmode="numeric" />
            <span asp-validation-for="TwoFactorCode" class="healan-field-error"></span>
        </div>

        <button type="submit" class="healan-btn healan-btn--primary">تأیید و ورود</button>

        <div asp-validation-summary="All" class="healan-validation"></div>
    </form>

    <p class="healan-login-note">
        کد تأیید برای مدت محدودی معتبر است. در صورت عدم دریافت، چند دقیقه صبر کنید و دوباره تلاش کنید.
    </p>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
