@model AddRole

@{
    ViewData["Title"] = "افزودن نقش";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

@if (ViewBag.Message != null)
{
    @* Alert Message *@
    <div class="@ViewBag.AlertMessage" style="text-align: right;direction: rtl;margin-bottom:10px;">
        <span class="closebtn" onclick="this.parentElement.style.display='none';">&times;</span>
        @ViewBag.Message
    </div>
}

<div class="row">
    <div class="col-lg-12">
        <section class="panel">

            <header class="panel-heading">
                افزودن نقش
            </header>

            <div class="panel-body">
                @using (Html.BeginForm("AddRole", "Account", FormMethod.Post, new { enctype = "multipart/form-data", @class = "form-horizontal tasi-form" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="form-horizontal">

                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        <div class="form-group">
                            @Html.LabelFor(model => model.Title, new { @class = "control-label col-sm-1" })
                            <div class="col-sm-5">
                                @Html.TextBoxFor(model => model.Title, new { @class = "form-control" })
                                <span class="help-block">
                                    @Html.ValidationMessageFor(model => model.Title, "", new { @class = "text-danger" })
                                </span>
                            </div>
                        </div>

                        <div class="form-group">
                            <div class="col-md-12 text-left">
                                <input type="submit" value="ورود اطلاعات" class="btn btn-success" />
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    </div>
</div>
