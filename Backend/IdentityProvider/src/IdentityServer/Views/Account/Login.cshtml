@using System.Collections.Generic
@using System.Linq
@using Microsoft.AspNetCore.Http

@model LoginViewModel
@inject SignInManager<ApplicationUser> SignInManager

@{
    ViewData["Title"] = "ورود";
    var base64Image = Convert.ToBase64String(Model.Image);
    var source = String.Format("data:image/png;base64,{0}", base64Image);
}

@*<p>@ViewBag.Message</p>*@

<div class="hotel-left">
    <div class="pay_form">
        <h3 class="text-login">ورود به سامانه جامع بورس اوراق بهادار</h3>
        <form asp-route-returnurl="@ViewData["ReturnUrl"]" asp-controller="Account" asp-action="Login" asp-antiforgery="true" method="post">

            <input asp-for="UserName" class="logo" placeholder="نام کاربری" />
            <input asp-for="Password" class="key password-custom" placeholder="رمز عبور" autocomplete='off'/>
            @Html.HiddenFor(x => x.CaptchaKey)
            @Html.HiddenFor(x => x.ReturnUrl)

            <div class="form-group">
                <div class="input-custom relative textbox_display">
                    @*@Html.TextBoxFor(model => model.CaptchaCode, new { @class = "form-control", placeholder = "کپچا" })*@
                    <input asp-for="CaptchaCode" class="Captchabox" placeholder="کد امنیتی" autocomplete='off'/>
                </div>
                <div class="input-group-prepend textbox_display">
                    <img src="@source" />
                </div>
            </div>
            <div class="form-group">
                <div class="col-md-offset-2 col-md-10">
                    <div class="checkbox">
                      @*  <input asp-for="RememberMe" />*@
                  @*      @Html.LabelFor(m => m.RememberMe, new { @class = "remember-custom" })*@
                        @Html.ActionLink("فراموشی رمز عبور","ForgotPassword","Account", new {returnUrl=Model.ReturnUrl}, new { @class = "link" })
                    </div>
                </div>
            </div>
            <div class="login-button text-left">
                <input type="submit" class="btn btn-success" value="ورود" />
            </div>

            <div asp-validation-summary="All" class="text-danger"></div>
        </form>
    </div>
    <div class="clear"></div>
</div>