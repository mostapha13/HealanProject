@using System.Collections.Generic
@using System.Linq
@using Microsoft.AspNetCore.Http

@model ResetPasswordViewModel

@{
    ViewData["Title"] = "تغییر رمز عبور";
    var captchaAvailable = Model?.Image != null && Model.Image.Length > 0;
    string source = captchaAvailable
        ? $"data:image/png;base64,{Convert.ToBase64String(Model.Image)}"
        : null;
}

<div class="hotel-left">
    <div class="pay_form">
        <h1 class="text-login">تغییر رمز عبور</h1>
        <form asp-route-returnurl="@ViewData["ReturnUrl"]" asp-controller="Account" asp-action="ResetPassword" asp-antiforgery="true" method="post">
            @Html.HiddenFor(x => x.PhoneNumber)
            @Html.HiddenFor(x => x.ReturnUrl)
            @Html.HiddenFor(x => x.CaptchaKey)
            <label asp-for="Code"></label>
            <input asp-for="Code" class="form-control" autocomplete="off" />
            <span asp-validation-for="Code" class="text-danger"></span>


            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control" autocomplete='off' />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" class="form-control" autocomplete='off' />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>
            @if (captchaAvailable)
            {
                  <div class="input-group-prepend">
                <img src="@source" alt="captcha" />
            </div>
            <div class="input-custom relative">
                <input asp-for="CaptchaCode" class="logo" placeholder="کد کپچا" autocomplete='off'/>
            </div>
            }
            <div class="login-button text-left">
                <input type="submit" class="btn btn-success" value="تایید" />
            </div>

            <div asp-validation-summary="All" class="text-danger"></div>
        </form>
    </div>
    <div class="clear"></div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
































