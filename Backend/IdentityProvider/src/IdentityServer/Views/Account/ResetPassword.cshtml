@using System.Collections.Generic
@using System.Linq
@using Microsoft.AspNetCore.Http

@model ResetPasswordViewModel

@{
    ViewData["Title"] = "تغییر رمز عبور";
    var captchaAvailable = Model?.Image != null && Model.Image.Length > 0;
    string source = captchaAvailable
        ? $"data:image/png;base64,{Convert.ToBase64String(Model.Image)}"
        : null;
}

<div class="healan-login-card">
    <header class="healan-login-card__header">
        <div class="healan-login-card__badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            رمز جدید
        </div>
        <h1 class="healan-login-card__title">تغییر رمز عبور</h1>
        <p class="healan-login-card__subtitle">کد دریافتی و رمز عبور جدید خود را وارد کنید.</p>
    </header>

    <form class="healan-login-form" asp-route-returnurl="@ViewData["ReturnUrl"]" asp-controller="Account" asp-action="ResetPassword" asp-antiforgery="true" method="post">
        @Html.HiddenFor(x => x.PhoneNumber)
        @Html.HiddenFor(x => x.ReturnUrl)
        @Html.HiddenFor(x => x.CaptchaKey)

        <div class="healan-field">
            <label asp-for="Code">کد تأیید</label>
            <input asp-for="Code" type="text" placeholder="کد ارسال‌شده" autocomplete="one-time-code" inputmode="numeric" />
            <span asp-validation-for="Code" class="healan-field-error"></span>
        </div>

        <div class="healan-field">
            <label asp-for="Password">رمز عبور جدید</label>
            <input asp-for="Password" type="password" placeholder="حداقل ۸ کاراکتر" autocomplete="new-password" />
            <span asp-validation-for="Password" class="healan-field-error"></span>
        </div>

        <div class="healan-field">
            <label asp-for="ConfirmPassword">تکرار رمز عبور</label>
            <input asp-for="ConfirmPassword" type="password" placeholder="رمز عبور را دوباره وارد کنید" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword" class="healan-field-error"></span>
        </div>

        @if (captchaAvailable)
        {
            <div class="healan-captcha">
                <div class="healan-field">
                    <label asp-for="CaptchaCode">کد امنیتی</label>
                    <input asp-for="CaptchaCode" type="text" placeholder="کد تصویر را وارد کنید" autocomplete="off" />
                    <span asp-validation-for="CaptchaCode" class="healan-field-error"></span>
                </div>
                <div class="healan-captcha__image">
                    <img src="@source" alt="کد امنیتی" />
                </div>
            </div>
        }

        <button type="submit" class="healan-btn healan-btn--primary">ذخیره رمز جدید</button>

        <div asp-validation-summary="All" class="healan-validation"></div>
    </form>

    <p class="healan-login-note">
        @Html.ActionLink("بازگشت به صفحه ورود", "Login", "Account", null, new { @class = "healan-link" })
    </p>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
