@using System.Collections.Generic
@using System.Linq
@using Microsoft.AspNetCore.Http

@model ForgotPasswordViewModel

@{
    ViewData["Title"] = "فراموشی رمز عبور";
    var hasImage = Model?.Image != null && Model.Image.Length > 0;
    string mime = "image/jpeg";
    if (hasImage && Model.Image.Length >= 4
        && Model.Image[0] == 0x89 && Model.Image[1] == 0x50 && Model.Image[2] == 0x4E && Model.Image[3] == 0x47)
        mime = "image/png";
    string source = hasImage
        ? $"data:{mime};base64,{Convert.ToBase64String(Model.Image)}"
        : null;
}

<div class="healan-login-card">
    <header class="healan-login-card__header">
        <div class="healan-login-card__badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            بازیابی دسترسی
        </div>
        <h1 class="healan-login-card__title">فراموشی رمز عبور</h1>
        <p class="healan-login-card__subtitle">شماره موبایل ثبت‌شده در سامانه را وارد کنید تا کد بازیابی ارسال شود.</p>
    </header>

    <form class="healan-login-form" asp-route-returnurl="@ViewData["ReturnUrl"]" asp-controller="Account" asp-action="ForgotPassword" asp-antiforgery="true" method="post">
        @Html.HiddenFor(x => x.CaptchaKey)
        @Html.HiddenFor(x => x.ReturnUrl)

        <div class="healan-field">
            <label asp-for="PhoneNumber">شماره موبایل</label>
            <input asp-for="PhoneNumber" type="tel" placeholder="۰۹۱۲۳۴۵۶۷۸۹" autocomplete="tel" inputmode="tel" />
            <span asp-validation-for="PhoneNumber" class="healan-field-error"></span>
        </div>

        <div class="healan-captcha">
            <div class="healan-field">
                <label asp-for="CaptchaCode">کد امنیتی</label>
                <input asp-for="CaptchaCode" type="text" placeholder="کد تصویر را وارد کنید" autocomplete="off" />
                <span asp-validation-for="CaptchaCode" class="healan-field-error"></span>
            </div>
            <div class="healan-captcha__image">
                @if (hasImage)
                {
                    <img src="@source" alt="کد امنیتی" />
                }
                else
                {
                    <span class="healan-field-error">تصویر کپچا بارگذاری نشد. صفحه را رفرش کنید.</span>
                }
            </div>
        </div>

        <button type="submit" class="healan-btn healan-btn--primary">ارسال کد بازیابی</button>

        <div asp-validation-summary="All" class="healan-validation"></div>
    </form>

    <p class="healan-login-note">
        @Html.ActionLink("بازگشت به صفحه ورود", "Login", "Account", new { ReturnUrl = Model?.ReturnUrl }, new { @class = "healan-link" })
    </p>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
