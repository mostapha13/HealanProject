    <script src="~/select2/select2.full.min.js"></script>
    <script src="~/scripts/jquery.validate.min.js"></script>
    <script src="~/scripts/jquery.validate.unobtrusive.min.js"></script>

    <script>

        //*********** Generate Comma */
        function numberWithCommas(x) {
            var result = x.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
            return result;
        }

        //************* Active Menu */
        $(function () {
            var pathName = window.location.pathname;
            var subQuery = window.location.search;
            var url = pathName + subQuery;
            $('#sidebar li').each(function () { $(this).removeClass('active'); });
            $('#sidebar a').each(function () {
                var self = $(this);
                var href = self.attr('href');
                self.removeClass('item-active');
                if (url == href) {
                    self.addClass('item-active');
                    var subParent = self.closest('ul');
                    if (subParent.hasClass('sub')) {
                        var subItemRoot = subParent.parent();
                        subItemRoot.addClass('active');
                    } else {
                        self.parent().addClass('active');
                    }
                    $('#sidebar').animate({ scrollTop: $("#sidebar .active").offset().top -= 100 }, 1500);
                }
            });
        });

    </script>

    @RenderSection("scripts", false)
</body>
</html>
