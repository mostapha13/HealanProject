<section class="healan-login-hero" aria-hidden="true">
    <div class="healan-login-hero__bg"></div>
    <div class="healan-login-hero__content">
        <div class="healan-login-hero__brand">
            <span class="healan-login-hero__logo" aria-hidden="true">
                <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="48" height="48" rx="14" fill="rgba(255,255,255,0.15)"/>
                    <path d="M24 12v24M12 24h24" stroke="#fff" stroke-width="3.5" stroke-linecap="round"/>
                </svg>
            </span>
            <div>
                <strong>Healan</strong>
                <span>سامانه مدیریت درمان</span>
            </div>
        </div>

        <h2 class="healan-login-hero__title">مراقبت هوشمند، مدیریت یکپارچه</h2>
        <p class="healan-login-hero__text">
            پلتفرم جامع مدیریت نوبت‌دهی، پرونده بیمار، نسخه‌نویسی و گزارش‌گیری برای کلینیک‌ها و مراکز درمانی.
        </p>

        <ul class="healan-login-hero__features">
            <li>
                <span class="healan-login-hero__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="9"/></svg>
                </span>
                نوبت‌دهی و صف ویزیت
            </li>
            <li>
                <span class="healan-login-hero__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12h6M9 16h6M9 8h6"/><rect x="4" y="3" width="16" height="18" rx="2"/></svg>
                </span>
                پرونده الکترونیک بیمار
            </li>
            <li>
                <span class="healan-login-hero__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </span>
                امنیت و حریم خصوصی
            </li>
        </ul>
    </div>

    <footer class="healan-login-hero__footer">
        <p>© @DateTime.Now.Year Healan — تمامی حقوق محفوظ است.</p>
    </footer>
</section>
