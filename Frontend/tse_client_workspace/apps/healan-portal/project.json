{
  "root": "apps/healan-portal",
  "sourceRoot": "apps/healan-portal/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nrwl/web:webpack",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "compiler": "swc",
        "outputPath": "dist/apps/healan-portal",
        "index": "apps/healan-portal/src/index.html",
        "baseHref": "/",
        "main": "apps/healan-portal/src/main.tsx",
        "polyfills": "apps/healan-portal/src/polyfills.ts",
        "tsConfig": "apps/healan-portal/tsconfig.app.json",
        "assets": ["apps/healan-portal/src/assets"],
        "styles": ["apps/healan-portal/src/styles.scss"],
        "scripts": [],
        "webpackConfig": "apps/healan-portal/webpack.config.js"
      },
      "configurations": {
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/healan-portal/src/environments/environment.ts",
              "with": "apps/healan-portal/src/environments/environment.prod.ts"
            }
          ],
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": false,
          "namedChunks": false,
          "extractLicenses": true,
          "vendorChunk": false
        }
      }
    },
    "serve": {
      "executor": "@nrwl/web:dev-server",
      "options": {
        "buildTarget": "healan-portal:build",
        "port": 4202,
        "hmr": true
      },
      "configurations": {
        "production": {
          "buildTarget": "healan-portal:build:production",
          "hmr": false
        }
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/healan-portal/**/*.{ts,tsx,js,jsx}"]
      }
    }
  },
  "tags": ["scope:healan", "type:app"]
}
