{
  "root": "apps/modern-instrumentations",
  "sourceRoot": "apps/modern-instrumentations/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nrwl/web:webpack",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "compiler": "swc",
        "outputPath": "apps/modern-instrumentations/build",
        "index": "apps/modern-instrumentations/src/index.html",
        "baseHref": "/",
        "main": "apps/modern-instrumentations/src/main.tsx",
        "polyfills": "apps/modern-instrumentations/src/polyfills.ts",
        "tsConfig": "apps/modern-instrumentations/tsconfig.app.json",
        "assets": ["apps/modern-instrumentations/src/favicon.png"],
        "styles": ["apps/modern-instrumentations/src/styles.scss"],
        "scripts": [],
        "webpackConfig": "@nrwl/react/plugins/webpack"
      },
      "configurations": {
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/modern-instrumentations/src/environments/environment.ts",
              "with": "apps/modern-instrumentations/src/environments/environment.prod.ts"
            }
          ],
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": false,
          "namedChunks": false,
          "extractLicenses": true,
          "vendorChunk": false
        }
      }
    },
    "serve": {
      "executor": "@nrwl/web:dev-server",
      "options": {
        "buildTarget": "modern-instrumentations:build",
        "hmr": true,
        "port": 4201
      },
      "configurations": {
        "production": {
          "buildTarget": "modern-instrumentations:build:production",
          "hmr": false
        }
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "apps/modern-instrumentations/**/*.{ts,tsx,js,jsx}"
        ]
      }
    }
  },
  "tags": []
}
