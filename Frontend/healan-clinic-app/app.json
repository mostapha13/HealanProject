{
  "expo": {
    "name": "کلینیک",
    "slug": "healan-clinic-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "healanclinic",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B6E4F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ir.drshahrooei.healan.clinic"
    },
    "android": {
      "package": "ir.drshahrooei.healan.clinic",
      "adaptiveIcon": {
        "backgroundColor": "#0B6E4F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "healanclinic",
              "host": "redirect"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "کلینیک",
      "shortName": "کلینیک",
      "themeColor": "#C6E000",
      "backgroundColor": "#F4F5F7",
      "display": "standalone",
      "lang": "fa"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/mobile"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e8260473-3855-417c-b7c1-5db2bf7c06e1"
      }
    },
    "owner": "mostaphamahdavi"
  }
}
